# Polymarket Market Maker Configuration
# Copy to .env and fill in your values

# ===================
# TRADING MODE
# ===================
# Set to "false" to enable live trading
# Default: true (safe mode)
DRY_RUN=true

# ===================
# POLYMARKET CREDENTIALS
# ===================
# Get these from https://polymarket.com/portfolio
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_base64_encoded_secret_here
POLYMARKET_PASSPHRASE=your_passphrase_here

# ===================
# SIGNER (Gnosis Safe)
# ===================
# Your Gnosis Safe address (L2 address)
POLYMARKET_SAFE_ADDRESS=0x...

# Private key for EIP-712 signing (DO NOT SHARE)
# This signs messages locally, never sent to API
POLYMARKET_PRIVATE_KEY=0x...

# ===================
# TRADING PARAMETERS
# ===================
# Edge threshold (micro-USDC) - $0.94 = 940000
EDGE_THRESHOLD=940000

# Maximum position per token (micro-USDC) - $5 = 5000000
MAX_POSITION=5000000

# ===================
# RATE LIMITING
# ===================
# Maximum burst capacity
RATE_LIMIT_BURST=300

# Requests per second
RATE_LIMIT_PER_SEC=50

# ===================
# WEBSOCKET
# ===================
# WebSocket URL (default: Polymarket)
WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Reconnect delay (seconds)
WS_RECONNECT_DELAY=5

# Maximum reconnect delay (seconds)
WS_MAX_RECONNECT_DELAY=60

# ===================
# LOGGING
# ===================
# Log level: trace, debug, info, warn, error
RUST_LOG=info

# ===================
# METRICS
# ===================
# Enable metrics output
METRICS_ENABLED=true

# Metrics interval (seconds)
METRICS_INTERVAL=60